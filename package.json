{
  "name": "aedilis",
  "version": "0.2.0",
  "private": true,
  "description": "LUDIARS Aedilis — facility reservation + schedule registration (Cernere SSO)",
  "type": "module",
  "scripts": {
    "predev": "npm run build:web",
    "dev": "tsx watch --env-file-if-exists=.env.secrets --env-file-if-exists=.env server/bootstrap.ts",
    "prestart": "npm run build:web",
    "start": "tsx --env-file-if-exists=.env.secrets --env-file-if-exists=.env server/bootstrap.ts",
    "build:web": "esbuild public/src/app.ts --bundle --outfile=public/app.js --target=es2020 --sourcemap --format=esm && esbuild public/src/checkin.ts --bundle --outfile=public/checkin.js --target=es2020 --sourcemap --format=esm",
    "watch:web": "esbuild public/src/app.ts public/src/checkin.ts --bundle --outdir=public --outbase=public/src --target=es2020 --sourcemap --format=esm --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.frontend.json",
    "test": "vitest run",
    "env:setup": "npx tsx ../Cernere/packages/env-cli/src/cli.ts setup",
    "env:test": "npx tsx ../Cernere/packages/env-cli/src/cli.ts test",
    "env:gen": "npx tsx ../Cernere/packages/env-cli/src/cli.ts env",
    "env:list": "npx tsx ../Cernere/packages/env-cli/src/cli.ts list",
    "env:get": "npx tsx ../Cernere/packages/env-cli/src/cli.ts get",
    "env:set": "npx tsx ../Cernere/packages/env-cli/src/cli.ts set",
    "env:initialize": "npx tsx ../Cernere/packages/env-cli/src/cli.ts initialize"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@ludiars/vestigium": "git+https://github.com/LUDIARS/Vestigium.git",
    "@simplewebauthn/browser": "^13.3.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.23",
    "paseto": "^3.1.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
